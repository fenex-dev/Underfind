override.cfg
*.env
secret.json
*.key
*.p12
*.keystore
*.jks

# Mono/C# ignores
.mono/
bin/
obj/
*.csproj
*.sln

# IDE-specific ignores
.idea/
.vscode/

# OS-specific ignores
.DS_Store
Thumbs.db
*.tmp

# Exported binaries/archives
*.exe
*.zip
*.tar.gz
*.dmg
*.app
*.apk
*.html
*.js
*.wasm
*.pck
